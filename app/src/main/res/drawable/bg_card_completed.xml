<?xml version="1.0" encoding="utf-8"?>
<layer-list xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- Main Card Background with rounded corners -->
    <item>
        <shape android:shape="rectangle">
            <solid android:color="@color/card_completed_border" />
            <corners android:radius="24dp" />
        </shape>
    </item>

    <!-- Green bar on the left -->
    <item android:bottom="0dp" android:left="6dp" android:right="0dp" android:top="0dp"> <!-- Only show on the very left -->
        <shape android:shape="rectangle">
            <solid android:color="@color/card_normal_bg" />
            <corners
                android:radius="24dp" />
        </shape>
    </item>
</layer-list>