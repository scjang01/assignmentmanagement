<?xml version="1.0" encoding="utf-8"?>

<!-- 
    ConstraintLayout: 뷰 간의 관계(제약 조건)를 설정하여 유연한 레이아웃을 만들 수 있는 레이아웃입니다. 
    상하좌우 연결선(app:layout_constraint...)을 통해 뷰의 위치를 결정합니다.
-->
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/background"
    tools:context=".MainActivity">

    <androidx.appcompat.widget.Toolbar
        android:id="@+id/toolbar"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:background="@color/toolbar_bg"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <TextView
            android:id="@+id/toolbar_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/toolbar_title"
            android:textColor="@color/toolbar_title"
            android:textSize="20sp"
            android:textStyle="bold" />

    </androidx.appcompat.widget.Toolbar>

    <LinearLayout
        android:id="@+id/ll_stats_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingHorizontal="24dp"
        android:paddingTop="16dp"
        android:paddingBottom="8dp"
        android:weightSum="4"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/toolbar">

        <!-- 진행중 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_marginEnd="4dp"
            android:background="@drawable/bg_stat_in_progress"
            android:elevation="2dp"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_in_progress"
                android:textColor="@color/stat_label"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_count_in_progress"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="12"
                android:textColor="@color/card_in_progress_border"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 임박 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_stat_urgent"
            android:elevation="2dp"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_urgent"
                android:textColor="@color/stat_label"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_count_urgent"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="03"
                android:textColor="@color/stat_urgent_text"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 완료 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_marginHorizontal="4dp"
            android:background="@drawable/bg_stat_completed"
            android:elevation="2dp"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_completed"
                android:textColor="@color/stat_label"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_count_completed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="08"
                android:textColor="@color/card_completed_border"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>

        <!-- 마감 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="72dp"
            android:layout_weight="1"
            android:layout_marginStart="4dp"
            android:background="@drawable/bg_stat_missed"
            android:elevation="2dp"
            android:gravity="center"
            android:orientation="vertical">
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/stat_missed"
                android:textColor="@color/stat_label"
                android:textSize="10sp"
                android:textStyle="bold" />
            <TextView
                android:id="@+id/tv_count_missed"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="01"
                android:textColor="@color/card_missed_border"
                android:textSize="20sp"
                android:textStyle="bold" />
        </LinearLayout>
    </LinearLayout>
    
    <!-- 
        RecyclerView: 대량의 리스트를 효율적으로 보여주는 위젯입니다.
        - 데이터 하나하나를 직접 만들지 않고, '틀(아이템 레이아웃)'에 데이터를 끼워넣어 보여줍니다.
        - 상단을 통계 바 하단에 맞춰 배치했습니다.
        - tools:listitem 옵션은 안드로이드 스튜디오 미리보기에서 아이템 형태를 확인할 때 유용합니다.
    -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_assignments"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingTop="8dp"
        android:paddingBottom="16dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintHorizontal_bias="0.0"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/ll_stats_bar"
        app:layout_constraintVertical_bias="0.0"
        tools:listitem="@layout/item_assignment" />

</androidx.constraintlayout.widget.ConstraintLayout>
